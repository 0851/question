mk = rm -rf upx/$(1)$(2)/$(3) \
&& mkdir -p upx/$(1)$(2) \
&& mkdir -p build/$(1)$(2) \
&& CGO_ENABLED=0 GOOS=$(1) GOARCH=$(2) go build -ldflags '-w -s' -o build/$(1)$(2)/$(3) \
&& upx -9 -o upx/$(1)$(2)/$(3) build/$(1)$(2)/$(3)

qs:
	
	$(call mk,windows,amd64,$@.exe)
	git add .
	git commit -am 'build...'
	git push